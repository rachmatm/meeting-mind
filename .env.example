# Copy to .env and fill in real values. Do NOT commit .env.

# Required: Neon (or other Postgres) DSN. sslmode=require is mandatory for Neon.
NEON_DSN=postgresql://USER:PASS@HOST/DBNAME?sslmode=require

# Required in Phase 3: Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-...

# Required in Phase 2: shared secret for n8n / webhook auth.
N8N_SHARED_SECRET=replace-me

# Optional, used in Phase 4 (embeddings).
VOYAGE_API_KEY=pa-...
# OPENAI_API_KEY=sk-...

# Optional, used in Phase 4 (Langfuse tracing).
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# Server.
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
