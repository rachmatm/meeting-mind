# Copy to .env and fill in real values. Do NOT commit .env.

# Required: Neon (or other Postgres) DSN. sslmode=require is mandatory for Neon.
NEON_DSN=postgresql://USER:PASS@HOST/DBNAME?sslmode=require

# Required: LLM API
LLM_BASE_URL=https://api.iamhc.cn/v1
LLM_API_KEY=sk-...
LLM_MODEL=glm-5.2

# Required: shared secret for n8n / webhook auth.
N8N_SHARED_SECRET=replace-me

# Notion (Phase 2)
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...

# Qdrant (Phase 2)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=  # optional

# Notifications (Phase 2)
# SLACK_BOT_TOKEN=  # optional
# WHATSAPP_API_URL=  # optional
# WHATSAPP_API_TOKEN=  # optional

# Optional (embeddings).
VOYAGE_API_KEY=pa-...
# OPENAI_API_KEY=sk-...

# Optional (Langfuse tracing).
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# Server.
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
